		"owners": { "repository": "unknown", "release": "unknown" },
		"engines": { "node": ">=18" },
		"packageManager": "pnpm@11.13.0",
		"typescript": "7.0.2",
		"requiredScripts": [
			"build",
			"lint",
			"typecheck",
			"test",
			"publint",
			"check:all"
		]
	},
