{
	"name": "@anvilkit/studio",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{md}\"",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"test:watch": "vitest",
		"changeset": "changeset",
		"changeset:status": "changeset status",
		"publint": "turbo run publint",
		"size": "turbo run size",
		"bench": "tsx --import ./bench/bench-env.mjs bench/index.ts",
		"bench:update": "tsx --import ./bench/bench-env.mjs bench/index.ts --update-baseline",
		"bench:collab-highload": "tsx bench/scenarios/collab-yjs-highload.ts",
		"madge": "madge --circular --extensions ts,tsx packages/",
		"docs:dev": "turbo run docs:dev",
		"docs:build": "turbo run docs:build"
	},
	"devDependencies": {
		"@anvilkit/bento-grid": "workspace:*",
		"@anvilkit/blog-list": "workspace:*",
		"@anvilkit/button": "workspace:*",
		"@anvilkit/core": "workspace:*",
		"@anvilkit/helps": "workspace:*",
		"@anvilkit/hero": "workspace:*",
		"@anvilkit/input": "workspace:*",
		"@anvilkit/ir": "workspace:*",
		"@anvilkit/logo-clouds": "workspace:*",
		"@anvilkit/navbar": "workspace:*",
		"@anvilkit/plugin-ai-copilot": "workspace:*",
		"@anvilkit/plugin-export-html": "workspace:*",
		"@anvilkit/plugin-version-history": "workspace:*",
		"@anvilkit/pricing-minimal": "workspace:*",
		"@anvilkit/section": "workspace:*",
		"@anvilkit/statistics": "workspace:*",
		"@biomejs/biome": "2.4.14",
		"@changesets/cli": "^2.31.0",
		"@puckeditor/core": "^0.21.2",
		"@rsbuild/plugin-react": "^2.0.0",
		"@rslib/core": "^0.21.5",
		"@size-limit/preset-small-lib": "^12.1.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.9.1",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitest/coverage-v8": "^4.1.7",
		"jsdom": "^29.1.1",
		"madge": "^8.0.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"publint": "^0.3.21",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"size-limit": "^11.2.0",
		"tinybench": "^3.1.1",
		"tsx": "^4.21.0",
		"turbo": "^2.9.14",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.11.0",
		"typescript": "6.0.3",
		"vitest": "^4.1.7",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
	},
	"packageManager": "pnpm@11.1.3",
	"engines": {
		"node": ">=22.13"
	}
}
