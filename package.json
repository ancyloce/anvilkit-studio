		"@anvilkit/statistics": "workspace:*",
		"@biomejs/biome": "2.5.3",
		"@changesets/cli": "^2.31.0",
		"@puckeditor/core": "^0.22.0",
		"@rsbuild/plugin-react": "^2.1.0",
		"@rslib/core": "^0.23.0",
		"@size-limit/preset-small-lib": "^12.1.0",
		"@testing-library/dom": "^10.4.1",
