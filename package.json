{
	"name": "@anvilkit/studio",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "turbo run format",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"test:watch": "vitest",
		"changeset": "changeset",
		"changeset:status": "changeset status",
		"publint": "turbo run publint",
		"check:all": "turbo run check:all --concurrency=4",
		"check:push": "turbo run check:all --concurrency=4 --filter=\"[${ANVILKIT_CHECK_BASE:-origin/main}]\"",
		"check:submodules": "node scripts/check-submodule-contracts.mjs",
		"size": "turbo run size",
		"madge": "madge --circular --extensions ts,tsx packages/",
		"docs:dev": "turbo run docs:dev",
		"docs:build": "turbo run docs:build",
		"prepare": "git config core.hooksPath .githooks || true",
		"doctor": "npx react-doctor@latest"
	},
	"devDependencies": {
		"@anvilkit/bento-grid": "workspace:*",
		"@anvilkit/blog-list": "workspace:*",
