{
  "name": "@anvilkit/studio",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "vitest",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "publint": "turbo run publint",
    "size": "turbo run size",
    "bench": "tsx bench/index.ts",
    "bench:update": "tsx bench/index.ts --update-baseline",
    "madge": "madge --circular --extensions ts,tsx packages/",
    "docs:dev": "turbo run docs:dev",
    "docs:build": "turbo run docs:build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@changesets/cli": "^2.30.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "size-limit": "^11.2.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "tinybench": "^3.1.1",
    "tsx": "^4.19.2",
    "turbo": "^2.8.20",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.4.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.4",
    "zod": "^4.3.0",
    "zustand": "^5.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19"
  }
}
