	"packageName": "@anvilkit/schema",
	"readme": [
		{
			"kind": "text",
			"text": "# @anvilkit/schema\n\nDerive AI-friendly component schemas from a Puck "
		},
		{
			"kind": "code",
			"text": "`Config`"
		},
		{
			"kind": "text",
			"text": ". The primary\nexports — "
		},
		{
			"kind": "code",
			"text": "`configToAiContext`"
		},
		{
			"kind": "text",
			"text": " and "
		},
		{
			"kind": "code",
			"text": "`extractFieldSchema`"
		},
		{
			"kind": "text",
			"text": " — map Puck config\nand field definitions to ["
		},
		{
			"kind": "code",
			"text": "`AiGenerationContext`"
		},
		{
			"kind": "text",
			"text": "]("
		},
		{
			"kind": "relative-link",
			"text": "../core/src/types/ai.ts",
			"target": 2
		},
		{
			"kind": "text",
			"text": ")\nand ["
		},
		{
			"kind": "code",
			"text": "`AiFieldSchema`"
		},
		{
			"kind": "text",
			"text": "]("
		},
		{
			"kind": "relative-link",
			"text": "../core/src/types/ai.ts",
			"target": 2
		},
		{
			"kind": "text",
			"text": ") that the AI copilot plugin\nfeeds into its system prompt.\n\n> **Alpha status (0.1.x).** "
		},
		{
			"kind": "code",
			"text": "`configToAiContext`"
		},
		{
			"kind": "text",
			"text": ", "
		},
		{
			"kind": "code",
			"text": "`identifySlotFields`"
		},
		{
			"kind": "text",
			"text": ",\n> "
		},
		{
			"kind": "code",
			"text": "`extractFieldSchema`"
		},
		{
			"kind": "text",
			"text": ", and "
		},
		{
			"kind": "code",
			"text": "`isJsonSerializable`"
		},
		{
			"kind": "text",
			"text": " are implemented and tested.\n\n## Install\n\n"
		},
		{
			"kind": "code",
			"text": "```bash\npnpm add @anvilkit/schema @puckeditor/core\n```"
		},
		{
			"kind": "text",
			"text": "\n\n## Quickstart\n\n"
		},
		{
			"kind": "code",
			"text": "```ts\nimport { configToAiContext } from \"@anvilkit/schema\";\nimport type { Config } from \"@puckeditor/core\";\n\ndeclare const puckConfig: Config;\n\nconst ctx = configToAiContext(puckConfig);\nconst firstComponent = ctx.availableComponents[0];\n\nconsole.log(firstComponent?.componentName);\n```"
		},
		{
			"kind": "text",
			"text": "\n\n### Per-field extraction\n\n"
		},
		{
			"kind": "code",
			"text": "```ts\nimport { extractFieldSchema } from \"@anvilkit/schema\";\nimport type { Field } from \"@puckeditor/core\";\n\nconst puckField: Field = { type: \"text\" };\nconst schema = extractFieldSchema(\"title\", puckField);\n// => { name: \"title\", type: \"text\" }\n```"
		},
		{
			"kind": "text",
			"text": "\n\n## Phase 3 references\n\nSee the [Phase 3 plan]("
		},
		{
			"kind": "relative-link",
			"text": "../../docs/plans/phase-3-export-ai-pipeline-plan.md",
			"target": 3
		},
		{
			"kind": "text",
			"text": ")\n("
		},
		{
			"kind": "code",
			"text": "`M2 — @anvilkit/schema`"
		},
		{
			"kind": "text",
			"text": ") and the\n[architecture package catalog]("
		},
		{
			"kind": "relative-link",
			"text": "../../docs/ai-context/anvilkit-architecture.md",
			"target": 4
		},
		{
			"kind": "text",
			"text": ")\n("
		},
		{
			"kind": "code",
			"text": "`§7 — @anvilkit/schema [Planned]`"
		},
		{
			"kind": "text",
			"text": ") for the schema-derivation role\nand dependency boundary.\n\n## Public API\n\n| Export                    | Signature                                                              | Purpose                                                       |\n| ------------------------- | ---------------------------------------------------------------------- | ------------------------------------------------------------- |\n| "
		},
		{
			"kind": "code",
			"text": "`configToAiContext`"
		},
		{
			"kind": "text",
			"text": "       | "
		},
		{
			"kind": "code",
			"text": "`(config: Config, opts?) => AiGenerationContext`"
		},
		{
			"kind": "text",
			"text": "                       | Derive full AI context from a Puck config.                    |\n| "
		},
		{
			"kind": "code",
			"text": "`identifySlotFields`"
		},
		{
			"kind": "text",
			"text": "     | "
		},
		{
			"kind": "code",
			"text": "`(config: Config) => Map<string, readonly string[]>`"
		},
		{
			"kind": "text",
			"text": "                   | Identify slot fields per component.                           |\n| "
		},
		{
			"kind": "code",
			"text": "`extractFieldSchema`"
		},
		{
			"kind": "text",
			"text": "     | "
		},
		{
			"kind": "code",
			"text": "`(name: string, field: Field, opts?) => AiFieldSchema`"
		},
		{
			"kind": "text",
			"text": "                 | Map a single Puck field to an AI-friendly schema.             |\n| "
		},
		{
			"kind": "code",
			"text": "`isJsonSerializable`"
		},
		{
			"kind": "text",
			"text": "     | "
		},
		{
			"kind": "code",
			"text": "`(value: unknown, opts?) => boolean`"
		},
		{
			"kind": "text",
			"text": "                                   | Check if a value is safe for JSON serialization.              |\n\n### "
		},
		{
			"kind": "code",
			"text": "`ConfigToAiContextOptions`"
		},
		{
			"kind": "text",
			"text": "\n\n| Option     | Type       | Default     | Description                                    |\n| ---------- | ---------- | ----------- | ---------------------------------------------- |\n| "
		},
		{
			"kind": "code",
			"text": "`include`"
		},
		{
			"kind": "text",
			"text": "  | "
		},
		{
			"kind": "code",
			"text": "`string[]`"
		},
		{
			"kind": "text",
			"text": " | all components | Whitelist a subset of components to include. |\n\n## Required heuristic\n\nPuck does not expose a per-field "
		},
		{
			"kind": "code",
			"text": "`required`"
		},
		{
			"kind": "text",
			"text": " flag. The heuristic used:\na field is considered required when its label is present and not empty.\nThis is conservative — override via "
		},
		{
			"kind": "code",
			"text": "`opts.required`"
		},
		{
			"kind": "text",
			"text": " if needed.\n\n## Dependency contract\n\n| Allowed                              | Forbidden                                                               |\n| ------------------------------------ | ----------------------------------------------------------------------- |\n| "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/utils`"
		},
		{
			"kind": "text",
			"text": " (runtime)          | "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/ir`"
		},
		{
			"kind": "text",
			"text": ", "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/validator`"
		},
		{
			"kind": "text",
			"text": ", "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/core`"
		},
		{
			"kind": "text",
			"text": " runtime         |\n| "
		},
		{
			"kind": "code",
			"text": "`@puckeditor/core`"
		},
		{
			"kind": "text",
			"text": " (peer, types-only)| React, ReactDOM, any plugin package, any DOM API                        |\n\n## Peer dependencies\n\n| Package | Version |\n| ------- | ------- |\n| "
		},
		{
			"kind": "code",
			"text": "`@puckeditor/core`"
		},
		{
			"kind": "text",
			"text": " | "
		},
		{
			"kind": "code",
			"text": "`^0.21.0`"
		},
		{
			"kind": "text",
			"text": " |"
		}
	],
