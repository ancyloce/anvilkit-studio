		{
			"id": 46,
			"name": "PageSeoSchema",
			"variant": "declaration",
			"kind": 32,
			"flags": {
				"isConst": true
			},
			"comment": {
				"summary": [
					{
						"kind": "text",
						"text": "Canonical SEO metadata block stored on a page's "
					},
					{
						"kind": "code",
						"text": "`root.props.seo`"
					},
					{
						"kind": "text",
						"text": ".\n\nField-name reconciliation with core's "
					},
					{
						"kind": "code",
						"text": "`StudioPageSeo`"
					},
					{
						"kind": "text",
						"text": "\n("
					},
					{
						"kind": "code",
						"text": "`@anvilkit/core`"
					},
					{
						"kind": "text",
						"text": " → "
					},
					{
						"kind": "code",
						"text": "`packages/core/src/types/pages.ts`"
					},
					{
						"kind": "text",
						"text": ") so F4 can project\n"
					},
					{
						"kind": "code",
						"text": "`root.props.seo`"
					},
					{
						"kind": "text",
						"text": " into the rail/breadcrumb sidecar losslessly:\n\n| This schema   | core "
					},
					{
						"kind": "code",
						"text": "`StudioPageSeo`"
					},
					{
						"kind": "text",
						"text": " | Note                          |\n| :------------ | :------------------- | :---------------------------- |\n| "
					},
					{
						"kind": "code",
						"text": "`title`"
					},
					{
						"kind": "text",
						"text": "       | "
					},
					{
						"kind": "code",
						"text": "`metaTitle`"
					},
					{
						"kind": "text",
						"text": "          | rename                        |\n| "
					},
					{
						"kind": "code",
						"text": "`description`"
					},
					{
						"kind": "text",
						"text": " | "
					},
					{
						"kind": "code",
						"text": "`metaDescription`"
					},
					{
						"kind": "text",
						"text": "    | rename                        |\n| "
					},
					{
						"kind": "code",
						"text": "`ogImage`"
					},
					{
						"kind": "text",
						"text": "     | "
					},
					{
						"kind": "code",
						"text": "`ogImage`"
					},
					{
						"kind": "text",
						"text": "            | identical                     |\n| "
					},
					{
						"kind": "code",
						"text": "`noIndex`"
					},
					{
						"kind": "text",
						"text": "     | "
					},
					{
						"kind": "code",
						"text": "`noindex`"
					},
					{
						"kind": "text",
						"text": "            | casing differs                |\n| "
					},
					{
						"kind": "code",
						"text": "`canonical`"
					},
					{
						"kind": "text",
						"text": "   | —                    | new; no core equivalent yet   |\n\nZod v4 idioms (mirrors "
					},
					{
						"kind": "code",
						"text": "`@anvilkit/core/src/config/schema.ts`"
					},
					{
						"kind": "text",
						"text": "):\n- "
					},
					{
						"kind": "code",
						"text": "`z.url()`"
					},
					{
						"kind": "text",
						"text": " not "
					},
					{
						"kind": "code",
						"text": "`z.string().url()`"
					},
					{
						"kind": "text",
						"text": " — top-level format validators.\n- "
					},
					{
						"kind": "code",
						"text": "`.prefault({})`"
					},
					{
						"kind": "text",
						"text": " not "
					},
					{
						"kind": "code",
						"text": "`.default({})`"
					},
					{
						"kind": "text",
						"text": " — "
					},
					{
						"kind": "code",
						"text": "`.default()`"
					},
					{
						"kind": "text",
						"text": " short-circuits parsing\n  and would yield a literal "
					},
					{
						"kind": "code",
						"text": "`{}`"
					},
					{
						"kind": "text",
						"text": "; "
					},
					{
						"kind": "code",
						"text": "`.prefault({})`"
					},
					{
						"kind": "text",
						"text": " re-parses so an omitted\n  "
					},
					{
						"kind": "code",
						"text": "`seo`"
					},
					{
						"kind": "text",
						"text": " block still resolves to "
					},
					{
						"kind": "code",
						"text": "`{ noIndex: false }`"
					},
					{
						"kind": "text",
						"text": "."
					}
				]
			},
			"type": {
				"type": "reference",
				"target": {
					"packageName": "zod",
					"packagePath": "v4/classic/schemas.d.cts",
					"qualifiedName": "ZodPrefault"
				},
				"typeArguments": [
					{
						"type": "reference",
