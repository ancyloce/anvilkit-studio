									{
										"kind": "text",
										"text": " to populate the root\n"
									},
									{
										"kind": "inline-tag",
										"tag": "@link",
										"text": "PageIR.assets"
									},
									{
										"kind": "text",
										"text": " manifest, and by node-scoped exporters\nthat want to resolve only their own slice of the asset graph.\n\n**Does not fetch or read files** — asset collection is purely\nstatic analysis of prop values."
									}
