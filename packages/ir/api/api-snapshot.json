											"qualifiedName": "PageIR"
										}
									},
									{
										"kind": "text",
										"text": ".\n\nThis function proves the round-trip guarantee — the invariant\n"
									},
									{
										"kind": "code",
										"text": "`irToPuckData(puckDataToIR(d)) ≡ d`"
									},
									{
										"kind": "text",
										"text": " is what lets us snapshot\ntest IR shapes without drift. It is also the entry point the AI\ncopilot plugin uses to turn a validated LLM "
									},
									{
										"kind": "code",
										"text": "`PageIR`"
									},
									{
										"kind": "text",
										"text": " response\nback into a "
