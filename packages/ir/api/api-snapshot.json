									},
									{
										"kind": "text",
										"text": " and return the set of field keys that\nbehave as "
									},
									{
										"kind": "code",
										"text": "`slot`"
									},
									{
										"kind": "text",
										"text": " (nested child-tree) fields, grouped by\ncomponent name.\n\nThe IR transform uses this to decide which prop values should be\ndescended into as "
									},
									{
										"kind": "inline-tag",
										"tag": "@link",
										"text": "import(\"@anvilkit/core/types\").PageIRNode.children | PageIRNode.children"
									},
									{
										"kind": "text",
										"text": "\nversus copied verbatim into "
									},
									{
										"kind": "inline-tag",
										"tag": "@link",
										"text": "import(\"@anvilkit/core/types\").PageIRNode.props | PageIRNode.props"
									},
									{
										"kind": "text",
										"text": ".\n\n### Detection heuristic\n\nA field is considered a slot if its "
									},
									{
										"kind": "code",
										"text": "`type`"
									},
									{
										"kind": "text",
										"text": " is "
									},
									{
										"kind": "code",
										"text": "`\"slot\"`"
									},
									{
										"kind": "text",
										"text": " (Puck's\nexplicit slot field type). This covers Puck 0.19+ where slot\nfields are first-class citizens in the field schema."
									}
								],
								"blockTags": [
									{
										"tag": "@returns",
										"content": [
											{
												"kind": "text",
												"text": "A map from component name to the list of slot-field keys\n  declared on that component. Components with no slots are\n  included with an empty array."
											}
										]
									}
								]
