{
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "root": false,
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**",
            "!dist",
            "!build"
        ]
    },
    "linter": {
        "enabled": true,
        "domains": {
            "react": "recommended"
        }
    }
}