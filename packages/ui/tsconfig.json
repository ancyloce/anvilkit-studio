{
	"extends": "@anvilkit/typescript-config/react-library.json",
	"compilerOptions": {
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"rootDir": "src",
		"paths": {
			"@anvilkit/ui": ["src"],
			"@anvilkit/ui/*": ["src/*"],
			"@anvilkit/ui/hooks": ["src/hooks"],
			"@anvilkit/ui/hooks/*": ["src/hooks/*"],
			"@anvilkit/ui/lib": ["src/lib"],
			"@anvilkit/ui/lib/utils": ["src/lib/utils.ts"],
			"@anvilkit/ui/lib/*": ["src/lib/*"]
		},
		"strictNullChecks": true,
		"useDefineForClassFields": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/index.ts", "src/*.tsx", "src/hooks/*.tsx", "src/lib/*.ts", "src/lib/*.tsx"],
	"exclude": ["node_modules", "dist", "src/components/**"]
}
