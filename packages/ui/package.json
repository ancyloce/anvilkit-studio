{
	"name": "@anvilkit/ui",
	"version": "0.0.1",
	"description": "Anvilkit shared UI primitives.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./globals.css": "./src/globals.css",
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js",
			"require": "./dist/*.cjs"
		},
		"./hooks/*": {
			"types": "./dist/hooks/*.d.ts",
			"import": "./dist/hooks/*.js",
			"require": "./dist/hooks/*.cjs"
		},
		"./lib/*": {
			"types": "./dist/lib/*.d.ts",
			"import": "./dist/lib/*.js",
			"require": "./dist/lib/*.cjs"
		}
	},
	"files": [
		"dist",
		"src/globals.css"
	],
	"license": "MIT",
	"sideEffects": [
		"**/*.css"
	],
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"scripts": {
		"build": "rslib build",
		"dev": "rslib build --watch",
		"lint": "pnpm exec biome lint package.json tsconfig.json rslib.config.ts src/**/*.ts src/**/*.tsx src/globals.css",
		"generate:component": "turbo gen react-component",
		"check-types": "tsc --noEmit",
		"test": "pnpm exec node --eval \"console.log('No tests configured for @anvilkit/ui')\""
	},
	"devDependencies": {
		"@anvilkit/biome-config": "workspace:*",
		"@anvilkit/typescript-config": "workspace:*",
		"@rsbuild/plugin-react": "^1.4.6",
		"@rslib/core": "^0.20.1",
		"@types/node": "^25.5.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"typescript": "6.0.2"
	},
	"dependencies": {
		"@radix-ui/react-slot": "1.2.4",
		"@base-ui/react": "^1.3.0",
		"@floating-ui/react": "^0.27.19",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"embla-carousel-react": "^8.6.0",
		"lucide-react": "^1.7.0",
		"motion": "^12.38.0",
		"next-themes": "^0.4.6",
		"react-use-measure": "^2.1.7",
		"shadcn": "^4.1.1",
		"shiki": "^4.0.2",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0"
	}
}
