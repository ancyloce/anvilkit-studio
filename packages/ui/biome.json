{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"root": false,
	"files": {
		"includes": [
			"package.json",
			"tsconfig.json",
			"rslib.config.ts",
			"src/index.ts",
			"src/*.tsx",
			"src/globals.css",
			"src/hooks/*.tsx",
			"src/lib/*.ts",
			"src/lib/*.tsx",
			"!dist/**"
		]
	},
	"extends": [
		"@anvilkit/biome-config/base",
		"@anvilkit/biome-config/react-internal"
	]
}
