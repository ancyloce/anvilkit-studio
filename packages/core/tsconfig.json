{
	"extends": "@anvilkit/typescript-config/react-library.json",
	"compilerOptions": {
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"rootDir": "src",
		"paths": {
			"@anvilkit/core/react/studio": ["src/react/studio"],
			"@anvilkit/core/react/studio/*": ["src/react/studio/*"],
			"@anvilkit/core/react/studio/primitives": [
				"src/react/studio/primitives"
			],
			"@anvilkit/core/react/studio/primitives/*": [
				"src/react/studio/primitives/*"
			],
			"@anvilkit/core/react/overrides/utils/cn": [
				"src/react/overrides/utils/cn.ts"
			],
			"@anvilkit/core/react/overrides/utils/*": [
				"src/react/overrides/utils/*"
			]
		},
		"strictNullChecks": true,
		"useDefineForClassFields": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"src/**/__tests__/**"
	]
}
