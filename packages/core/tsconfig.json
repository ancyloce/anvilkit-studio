{
	"extends": "@anvilkit/typescript-config/react-library.json",
	"compilerOptions": {
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"rootDir": "src",
		"paths": {
			"@/studio": ["src/react/studio"],
			"@/studio/*": ["src/react/studio/*"],
			"@/primitives": ["src/react/studio/primitives"],
			"@/primitives/*": ["src/react/studio/primitives/*"],
			"@/utils/cn": ["src/react/overrides/utils/cn.ts"],
			"@/utils/*": ["src/react/overrides/utils/*"],
			"@/hooks": ["src/react/studio/hooks"],
			"@/hooks/*": ["src/react/studio/hooks/*"]
		},
		"strictNullChecks": true,
		"useDefineForClassFields": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"src/**/__tests__/**"
	]
}
