{
	"extends": "@anvilkit/typescript-config/react-library.json",
	"compilerOptions": {
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"rootDir": "src",
		"paths": {
			"@/studio": ["src/react/studio"],
			"@/studio/*": ["src/react/studio/*"],
			"@/primitives": ["src/react/studio/primitives"],
			"@/primitives/*": ["src/react/studio/primitives/*"],
			"@/state": ["src/react/studio/state"],
			"@/state/*": ["src/react/studio/state/*"],
			"@/canvas-drop": ["src/react/studio/canvas-drop"],
			"@/canvas-drop/*": ["src/react/studio/canvas-drop/*"],
			"@/context": ["src/react/studio/context"],
			"@/context/*": ["src/react/studio/context/*"],
			"@/layout": ["src/react/studio/layout"],
			"@/layout/*": ["src/react/studio/layout/*"],
			"@/theme": ["src/react/studio/theme"],
			"@/theme/*": ["src/react/studio/theme/*"],
			"@/ui": ["src/react/studio/ui"],
			"@/ui/*": ["src/react/studio/ui/*"],
			"@/components": ["src/react/components"],
			"@/components/*": ["src/react/components/*"],
			"@/hooks": ["src/react/hooks"],
			"@/hooks/*": ["src/react/hooks/*"],
			"@/overrides": ["src/react/overrides"],
			"@/overrides/*": ["src/react/overrides/*"],
			"@/utils/cn": ["src/react/overrides/utils/cn.ts"],
			"@/utils/*": ["src/react/overrides/utils/*"],
			"@/stores": ["src/react/stores"],
			"@/stores/*": ["src/react/stores/*"],
			"@/compat": ["src/compat"],
			"@/compat/*": ["src/compat/*"],
			"@/config": ["src/config"],
			"@/config/*": ["src/config/*"],
			"@/runtime": ["src/runtime"],
			"@/runtime/*": ["src/runtime/*"],
			"@/section": ["src/section"],
			"@/section/*": ["src/section/*"],
			"@/templates": ["src/templates"],
			"@/templates/*": ["src/templates/*"],
			"@/testing": ["src/testing"],
			"@/testing/*": ["src/testing/*"],
			"@/types": ["src/types"],
			"@/types/*": ["src/types/*"]
		},
		// `strict: true` (inherited from base.json) already implies
		// `strictNullChecks`, so the local override was redundant and is
		// dropped (review finding TS-2).
		//
		// `exactOptionalPropertyTypes` is intentionally LEFT OFF (review
		// finding TS-1): the IR contract trades on omit-vs-present, but the
		// real transform lives in `@anvilkit/ir` (Zod-enforced;
		// `JSON.stringify` drops `undefined`). Enabling it surfaces ~59
		// prop-passing mismatches against Puck's own prop types for no
		// runtime benefit, so the omission is deliberate.
		"useDefineForClassFields": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"src/**/__tests__/**"
	]
}
