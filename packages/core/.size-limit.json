[
	{
		"name": "@anvilkit/core (full index — tracks total surface; Studio entry is gated separately by check:bundle-budget)",
		"path": "dist/index.js",
		"limit": "560 KB",
		"gzip": true,
		"ignore": [
			"react",
			"react-dom",
			"react/jsx-runtime",
			"react/jsx-dev-runtime",
			"@puckeditor/core",
			"*.css"
		]
	},
	{
		"name": "@anvilkit/core/i18n/icu (optional ICU formatter — dependency-free)",
		"path": "dist/i18n/icu/index.js",
		"limit": "3 KB",
		"gzip": true
	}
]
