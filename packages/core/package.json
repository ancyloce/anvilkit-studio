{
	"name": "@anvilkit/core",
	"version": "0.1.17",
	"description": "Anvilkit Studio runtime — types, plugin engine, React shell, and config system for the Puck-native visual editor.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./types": {
			"import": {
				"types": "./dist/types/index.d.ts",
				"default": "./dist/types/index.js"
			},
			"require": {
				"types": "./dist/types/index.d.cts",
				"default": "./dist/types/index.cjs"
			}
		},
		"./runtime": {
			"import": {
				"types": "./dist/runtime/index.d.ts",
				"default": "./dist/runtime/index.js"
			},
			"require": {
				"types": "./dist/runtime/index.d.cts",
				"default": "./dist/runtime/index.cjs"
			}
		},
		"./config": {
			"import": {
				"types": "./dist/config/index.d.ts",
				"default": "./dist/config/index.js"
			},
			"require": {
				"types": "./dist/config/index.d.cts",
				"default": "./dist/config/index.cjs"
			}
		},
		"./i18n": {
			"import": {
				"types": "./dist/i18n/index.d.ts",
				"default": "./dist/i18n/index.js"
			},
			"require": {
				"types": "./dist/i18n/index.d.cts",
				"default": "./dist/i18n/index.cjs"
			}
		},
		"./i18n/icu": {
			"import": {
				"types": "./dist/i18n/icu/index.d.ts",
				"default": "./dist/i18n/icu/index.js"
			},
			"require": {
				"types": "./dist/i18n/icu/index.d.cts",
				"default": "./dist/i18n/icu/index.cjs"
			}
		},
		"./react": {
			"import": {
				"types": "./dist/react/index.d.ts",
				"default": "./dist/react/index.js"
			},
			"require": {
				"types": "./dist/react/index.d.cts",
				"default": "./dist/react/index.cjs"
			}
		},
		"./compat": {
			"import": {
				"types": "./dist/compat/index.d.ts",
				"default": "./dist/compat/index.js"
			},
			"require": {
				"types": "./dist/compat/index.d.cts",
				"default": "./dist/compat/index.cjs"
			}
		},
		"./testing": {
			"import": {
				"types": "./dist/testing/index.d.ts",
				"default": "./dist/testing/index.js"
			},
			"require": {
				"types": "./dist/testing/index.d.cts",
				"default": "./dist/testing/index.cjs"
			}
		},
		"./templates": {
			"import": {
				"types": "./dist/templates/index.d.ts",
				"default": "./dist/templates/index.js"
			},
			"require": {
				"types": "./dist/templates/index.d.cts",
				"default": "./dist/templates/index.cjs"
			}
		},
		"./section": {
			"import": {
				"types": "./dist/section/index.d.ts",
				"default": "./dist/section/index.js"
			},
			"require": {
				"types": "./dist/section/index.d.cts",
				"default": "./dist/section/index.cjs"
			}
		},
		"./react/overrides": {
			"import": {
				"types": "./dist/react/overrides/index.d.ts",
				"default": "./dist/react/overrides/index.js"
			},
			"require": {
				"types": "./dist/react/overrides/index.d.cts",
				"default": "./dist/react/overrides/index.cjs"
			}
		},
		"./styles.css": "./dist/react/overrides/styles.css"
	},
	"files": [
		"dist",
		"i18n"
	],
	"license": "MIT",
	"sideEffects": [
		"**/*.css"
	],
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@puckeditor/core": "^0.21.3",
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"dependencies": {
		"@anvilkit/analytics-core": "workspace:*",
		"@anvilkit/ui": "workspace:*",
		"@anvilkit/utils": "workspace:*",
		"@base-ui/react": "^1.6.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@tanstack/react-virtual": "^3.13.24",
		"@tiptap/pm": "^3.27.1",
		"@tiptap/react": "^3.27.1",
		"@tiptap/starter-kit": "^3.27.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.17.0",
		"motion": "^12.38.0",
		"next-themes": "^0.4.6",
		"react-resizable-panels": "^4.11.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@anvilkit/biome-config": "workspace:*",
		"@anvilkit/typescript-config": "workspace:*",
		"@anvilkit/vitest-config": "workspace:*",
		"@puckeditor/core": "^0.21.3",
		"@rsbuild/plugin-react": "^2.0.0",
		"@rslib/core": "^0.23.0",
		"@tailwindcss/cli": "4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "19.2.3",
		"esbuild": "^0.28.0",
		"jsdom": "^29.1.1",
		"madge": "^8.0.0",
		"publint": "^0.3.21",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tailwindcss": "4.2.2",
		"tw-animate-css": "^1.4.0",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.11.0",
		"typescript": "6.0.3",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.1.9"
	},
	"scripts": {
		"build": "rslib build && pnpm build:css",
		"build:css": "tailwindcss -i ./src/react/overrides/styles.src.css -o ./dist/react/overrides/styles.css --minify",
		"dev": "rslib build --watch",
		"lint": "pnpm exec biome lint package.json tsconfig.json tsconfig.test.json rslib.config.ts vitest.config.ts src scripts",
		"format": "pnpm exec biome check --write package.json tsconfig.json tsconfig.test.json rslib.config.ts vitest.config.ts src scripts",
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"publint": "publint",
		"check:publint": "publint .",
		"check:circular": "madge --circular --extensions ts,tsx src/",
		"check:react-free-runtime": "node ./scripts/check-react-free.mjs",
		"check:no-headless-import": "node ./scripts/check-no-headless-import.mjs",
		"check:peer-deps": "node ./scripts/check-peer-deps.mjs",
		"check:bundle-budget": "node ./scripts/check-bundle-budget.mjs",
		"check:api-snapshot": "typedoc --json ./api/api-snapshot.json --entryPoints ./src/index.ts --tsconfig ./tsconfig.json --logLevel Warn",
		"check:api-snapshot-runtime": "typedoc --json ./api/api-snapshot.runtime.json --entryPoints ./src/runtime/index.ts --tsconfig ./tsconfig.json --logLevel Warn",
		"check:api-snapshot-config": "typedoc --json ./api/api-snapshot.config.json --entryPoints ./src/config/index.ts --tsconfig ./tsconfig.json --logLevel Warn",
		"check:api-snapshot-i18n": "typedoc --json ./api/api-snapshot.i18n.json --entryPoints ./src/i18n/index.ts --tsconfig ./tsconfig.json --logLevel Warn",
		"check:api-snapshot-icu": "typedoc --json ./api/api-snapshot.icu.json --entryPoints ./src/i18n/icu/index.ts --tsconfig ./tsconfig.json --logLevel Warn",
		"check:api-snapshot-react": "typedoc --json ./api/api-snapshot.react.json --entryPoints ./src/react/index.ts --tsconfig ./tsconfig.json --logLevel Warn",
		"check:api-snapshot-templates": "typedoc --options ./typedoc.templates.json --json ./api/api-snapshot.templates.json",
		"check:api-snapshot-verify": "git diff --exit-code -- ./api",
		"check:api-snapshot-all": "pnpm check:api-snapshot && pnpm check:api-snapshot-runtime && pnpm check:api-snapshot-config && pnpm check:api-snapshot-i18n && pnpm check:api-snapshot-icu && pnpm check:api-snapshot-react && pnpm check:api-snapshot-templates",
		"check:all": "pnpm check:publint && pnpm check:circular && pnpm check:react-free-runtime && pnpm check:no-headless-import && pnpm check:peer-deps && pnpm check:bundle-budget && pnpm check:api-snapshot-all && pnpm check:api-snapshot-verify",
		"migrate:shadcn-paths": "node ./scripts/migrate-shadcn-paths.mjs",
		"size": "size-limit"
	}
}
