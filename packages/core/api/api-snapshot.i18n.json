			],
			"signatures": [
				{
					"id": 21,
					"name": "mergeCatalog",
					"variant": "signature",
					"kind": 4096,
					"flags": {},
					"comment": {
						"summary": [
							{
								"kind": "text",
								"text": "Merge registry entries into a single flat catalog for "
							},
							{
								"kind": "code",
								"text": "`locale`"
							},
							{
								"kind": "text",
								"text": ".\n\nResolution (P0 §B.4):\n  1. Entries are applied in array order; core seeds ("
							},
							{
								"kind": "code",
								"text": "`studio`"
							},
							{
								"kind": "text",
								"text": ",\n     "
							},
							{
								"kind": "code",
								"text": "`assetManager`"
							},
							{
								"kind": "text",
								"text": ") come first so plugins cannot shadow chrome keys.\n  2. Per entry the source bundle is "
							},
							{
								"kind": "code",
								"text": "`entry.en`"
							},
							{
								"kind": "text",
								"text": " **overlaid by** the\n     resolved locale pack ("
							},
							{
								"kind": "code",
								"text": "`loaded.get(`"
							},
							{
								"kind": "text",
								"text": "${ns}:${locale}"
							},
							{
								"kind": "code",
								"text": "`)`"
							},
							{
								"kind": "text",
								"text": ") when present,\n     so a *partial* pack falls back to English per missing key (and a\n     not-yet-loaded pack shows English while it loads).\n  3. Namespace guard: for a non-reserved namespace, a key that does not\n     start with "
							},
							{
								"kind": "code",
								"text": "`${namespace}.`"
							},
							{
								"kind": "text",
								"text": " is dropped and reported via\n     "
							},
							{
								"kind": "code",
								"text": "`onViolation`"
							},
							{
								"kind": "text",
								"text": " (the provider wires this to "
							},
							{
								"kind": "code",
								"text": "`ctx.log(\"warn\", …)`"
							},
							{
								"kind": "text",
								"text": ").\n  4. Exact-key collisions resolve last-write-wins; the guard makes\n     cross-namespace collisions structurally impossible, so in practice\n     only a namespace's own later pack overwrites its own keys."
							}
						]
					},
