							"packagePath": "src/types/ir.ts",
							"qualifiedName": "PageIR"
						}
					},
					{
						"kind": "text",
						"text": "\ndepends on.\n\nTemplates enumerate their package graph explicitly (rather than\nderiving it from "
					},
					{
						"kind": "code",
						"text": "`pageIR`"
					},
					{
						"kind": "text",
						"text": ") so a docs catalog can list dependencies\nwithout walking the tree and so a future installer can resolve a\nlockfile from the manifest alone."
					}
				]
			},
