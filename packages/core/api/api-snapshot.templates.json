			"comment": {
				"summary": [
					{
						"kind": "text",
						"text": "A static preview image for a template — produced once per template\nby the Playwright capture pipeline ("
					},
					{
						"kind": "code",
						"text": "`phase5-017`"
					},
					{
						"kind": "text",
						"text": "). Consumed by the\ndocs catalog and CLI picker to render a thumbnail before the\ntemplate's full IR is loaded.\n\nDimensions are carried alongside the URL so catalog layouts can\nreserve space without a network round-trip, and "
					},
					{
						"kind": "code",
						"text": "`alt`"
					},
					{
						"kind": "text",
						"text": " is required\n(not optional) so every catalog card has accessible text by\ndefault."
					}
				]
			},
