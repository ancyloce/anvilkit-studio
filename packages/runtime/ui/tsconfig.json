{
	"extends": "@anvilkit/typescript-config/react-library.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"rootDir": "src",
		"paths": {
			// Source-only alias for shadcn write targets. Distinct from the
			// published `@anvilkit/ui` name so it is NOT shadowed by the
			// package `exports` self-reference (which resolves into ./dist).
			// shadcn falls back to these tsconfig paths → files land in src/.
			"@ui-src": ["./src"],
			"@ui-src/*": ["./src/*"],
			"@anvilkit/ui": ["./src"],
			"@anvilkit/ui/*": ["./src/*"],
			"@anvilkit/ui/hooks": ["./src/hooks"],
			"@anvilkit/ui/hooks/*": ["./src/hooks/*"],
			"@anvilkit/ui/lib": ["./src/lib"],
			"@anvilkit/ui/lib/utils": ["./src/lib/utils.ts"],
			"@anvilkit/ui/lib/*": ["./src/lib/*"]
		},
		"strictNullChecks": true,
		"useDefineForClassFields": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"src/**/__tests__/**"
	]
}
