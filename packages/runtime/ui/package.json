{
	"name": "@anvilkit/ui",
	"version": "0.1.18",
	"description": "Anvilkit shared UI primitives.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/cjs/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./globals.css": "./src/globals.css",
		"./presence": {
			"import": {
				"types": "./dist/presence/index.d.ts",
				"default": "./dist/presence/index.js"
			},
			"require": {
				"types": "./dist/cjs/presence/index.d.cts",
				"default": "./dist/presence/index.cjs"
			}
		},
		"./presence/*": {
			"import": {
				"types": "./dist/presence/*.d.ts",
				"default": "./dist/presence/*.js"
			},
			"require": {
				"types": "./dist/cjs/presence/*.d.cts",
				"default": "./dist/presence/*.cjs"
			}
		},
		"./*": {
			"import": {
				"types": "./dist/*.d.ts",
				"default": "./dist/*.js"
			},
			"require": {
				"types": "./dist/cjs/*.d.cts",
				"default": "./dist/*.cjs"
			}
		},
		"./hooks/*": {
			"import": {
				"types": "./dist/hooks/*.d.ts",
				"default": "./dist/hooks/*.js"
			},
			"require": {
				"types": "./dist/cjs/hooks/*.d.cts",
				"default": "./dist/hooks/*.cjs"
			}
		},
		"./lib/*": {
			"import": {
				"types": "./dist/lib/*.d.ts",
				"default": "./dist/lib/*.js"
			},
			"require": {
				"types": "./dist/cjs/lib/*.d.cts",
				"default": "./dist/lib/*.cjs"
			}
		}
	},
	"files": [
		"dist",
		"src/globals.css"
	],
	"license": "MIT",
	"sideEffects": [
		"**/*.css"
	],
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"scripts": {
		"build": "rslib build --lib esm && rslib build --lib cjs --no-clean",
		"dev": "rslib build --watch",
		"lint": "pnpm exec biome lint package.json tsconfig.json rslib.config.ts vitest.config.ts src/**/*.ts src/**/*.tsx src/globals.css",
		"generate:component": "turbo gen react-component",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"publint": "publint",
		"size": "size-limit"
	},
	"devDependencies": {
		"@anvilkit/biome-config": "workspace:*",
		"@anvilkit/typescript-config": "workspace:*",
		"@anvilkit/vitest-config": "workspace:*",
		"@rsbuild/plugin-react": "^2.1.0",
		"@rslib/core": "^0.23.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "19.2.3",
		"jsdom": "^29.1.1",
		"publint": "^0.3.21",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"typescript": "7.0.2",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@tanstack/react-virtual": "^3.13.24",
		"@floating-ui/react": "^0.27.19",
		"@radix-ui/react-slot": "1.2.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"embla-carousel-react": "^8.6.0",
		"lucide-react": "^1.24.0",
		"motion": "^12.42.2",
		"next-themes": "^0.4.6",
		"react-use-measure": "^2.1.7",
		"shadcn": "^4.1.1",
		"shiki": "^4.0.2",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"vaul": "^1.1.2"
	}
}
