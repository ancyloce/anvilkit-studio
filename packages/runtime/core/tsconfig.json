{
	"extends": "@anvilkit/typescript-config/react-library.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"rootDir": "src",
		"paths": {
			"@/studio": ["./src/studio"],
			"@/studio/*": ["./src/studio/*"],
			"@/primitives": ["./src/studio/primitives"],
			"@/primitives/*": ["./src/studio/primitives/*"],
			"@/state": ["./src/state"],
			"@/state/*": ["./src/state/*"],
			"@/canvas-drop": ["./src/studio/canvas-drop"],
			"@/canvas-drop/*": ["./src/studio/canvas-drop/*"],
			"@/context": ["./src/studio/context"],
			"@/context/*": ["./src/studio/context/*"],
			"@/layout": ["./src/studio/layout"],
			"@/layout/*": ["./src/studio/layout/*"],
			"@/theme": ["./src/studio/theme"],
			"@/theme/*": ["./src/studio/theme/*"],
			"@/ui": ["./src/studio/ui"],
			"@/ui/*": ["./src/studio/ui/*"],
			"@/components": ["./src/react/components"],
			"@/components/*": ["./src/react/components/*"],
			"@/overrides": ["./src/react/overrides"],
			"@/overrides/*": ["./src/react/overrides/*"],
			"@/shared": ["./src/shared"],
			"@/shared/*": ["./src/shared/*"],
			"@/utils/*": ["./src/react/overrides/utils/*"],
			"@/compat": ["./src/compat"],
			"@/compat/*": ["./src/compat/*"],
			"@/config": ["./src/config"],
			"@/config/*": ["./src/config/*"],
			"@/export": ["./src/export"],
			"@/export/*": ["./src/export/*"],
			"@/i18n": ["./src/i18n"],
			"@/i18n/*": ["./src/i18n/*"],
			"@/runtime": ["./src/runtime"],
			"@/runtime/*": ["./src/runtime/*"],
			"@/section": ["./src/section"],
			"@/section/*": ["./src/section/*"],
			"@/templates": ["./src/templates"],
			"@/templates/*": ["./src/templates/*"],
			"@/testing": ["./src/testing"],
			"@/testing/*": ["./src/testing/*"],
			"@/types": ["./src/types"],
			"@/types/*": ["./src/types/*"]
		},
		// `strict: true` (inherited from base.json) already implies
		// `strictNullChecks`, so the local override was redundant and is
		// dropped (review finding TS-2).
		//
		// `exactOptionalPropertyTypes` is intentionally LEFT OFF (review
		// finding TS-1): the IR contract trades on omit-vs-present, but the
		// real transform lives in `@anvilkit/ir` (Zod-enforced;
		// `JSON.stringify` drops `undefined`). Enabling it surfaces ~59
		// prop-passing mismatches against Puck's own prop types for no
		// runtime benefit, so the omission is deliberate.
		"useDefineForClassFields": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"src/**/__tests__/**"
	]
}
