# Copy to `.env` for local runs (`node server.mjs`). On Fly, non-secret
# values live in fly.toml [env]; secrets go through `fly secrets set`.

# Port the relay listens on (Fly maps 443 -> this).
PORT=1234
HOCUSPOCUS_NAME=anvilkit-collab

# DURABLE mode: Redis (Upstash) connection string. `rediss://` enables
# TLS. Leave UNSET to run EPHEMERAL/in-memory locally (no persistence,
# single instance) — handy for a quick smoke test.
# REDIS_URL=rediss://default:PASSWORD@your-db.upstash.io:6379

# Restrict WS origins (comma-separated). Empty = allow any origin.
COLLAB_ALLOWED_ORIGINS=https://anvilkit.dev

# Optional: require this exact token. The playground sends it via the
# PUBLIC_COLLAB_WS_TOKEN build env. Leave unset for an OPEN demo relay.
# COLLAB_AUTH_TOKEN=

# Optional key prefixes for the Redis keyspace.
# COLLAB_DOC_PREFIX=anvilkit:collab:doc:
# COLLAB_REDIS_PREFIX=anvilkit:collab
