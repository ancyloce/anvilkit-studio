{
	"name": "studio",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "pnpm --filter @anvilkit/canvas-editor build:css && COLLAB_RELAY_KIND=hocuspocus node scripts/dev-collab.mjs",
		"dev:next-only": "next dev --webpack",
		"dev:turbopack": "next dev",
		"dev:collab": "node scripts/dev-collab.mjs",
		"relay": "node ../../packages/plugins/plugin-collab-yjs/examples/y-websocket-server.mjs ${COLLAB_RELAY_PORT:-21234}",
		"relay:hocuspocus": "node scripts/hocuspocus-dev-relay.mjs ${COLLAB_HOCUSPOCUS_PORT:-31234}",
		"build": "pnpm --filter @anvilkit/canvas-editor build:css && next build --webpack",
		"start": "next start",
		"lint": "pnpm exec biome lint .",
		"typecheck": "next typegen && tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"drizzle:generate": "drizzle-kit generate",
		"e2e": "playwright test",
		"e2e:install": "playwright install --with-deps chromium"
	},
	"dependencies": {
		"@anvilkit/analytics-core": "workspace:*",
