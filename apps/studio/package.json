		"@anvilkit/ui": "workspace:*",
		"@anvilkit/validator": "workspace:*",
		"@gsap/react": "^2.1.2",
		"@hocuspocus/provider": "^4.3.0",
		"@puckeditor/core": "^0.22.0",
		"better-sqlite3": "^12.11.1",
