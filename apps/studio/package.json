		"@anvilkit/logo-clouds": "workspace:*",
		"@anvilkit/navbar": "workspace:*",
		"@anvilkit/plugin-ai-copilot": "workspace:*",
		"@anvilkit/plugin-ai-image": "workspace:*",
		"@anvilkit/plugin-asset-manager": "workspace:*",
		"@anvilkit/plugin-canvas-studio": "workspace:*",
		"@anvilkit/plugin-collab-yjs": "workspace:*",
