{
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules", "dist", ".output", ".nitro", ".vercel", "tests"],
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["vite/client"],
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"target": "ES2022",
		"allowJs": true,
		"forceConsistentCasingInFileNames": true,
		"paths": {
			"@/*": ["./src/*"],
			"@scripts/*": ["./scripts/*"],
			"collections/*": ["./.source/*"]
		},
		"noEmit": true
	}
}
