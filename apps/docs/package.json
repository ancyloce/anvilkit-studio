{
	"name": "@anvilkit/docs-site",
	"version": "0.0.4",
	"private": true,
	"type": "module",
	"scripts": {
		"generate:components": "jiti scripts/generate-component-pages.ts",
		"generate:api": "jiti scripts/generate-api-pages.ts",
		"generate:templates": "node scripts/generate-template-pages.mjs",
		"generate:registry": "jiti scripts/generate-registry-feed.ts",
		"generate:all": "pnpm generate:components && pnpm generate:api && pnpm generate:templates && pnpm generate:registry",
		"prebuild": "pnpm generate:all",
		"predev": "pnpm generate:all",
		"dev": "astro dev --host 0.0.0.0 --port 4321",
		"docs:dev": "astro dev --host 0.0.0.0 --port 4321",
		"relay:hocuspocus": "node integrations/collab-relay.mjs",
		"build": "astro build",
		"docs:build": "astro build",
		"preview": "astro preview --host 0.0.0.0 --port 4321",
		"astro": "astro",
		"typecheck": "astro check",
		"test": "vitest run",
		"test:watch": "vitest",
		"e2e": "playwright test",
		"e2e:install": "playwright install --with-deps chromium"
	},
	"dependencies": {
		"@anvilkit/bento-grid": "workspace:*",
