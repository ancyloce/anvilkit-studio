		"@anvilkit/plugin-canvas-studio": "workspace:*",
		"@anvilkit/plugin-collab-yjs": "workspace:*",
		"@anvilkit/plugin-design-system": "workspace:*",
		"@anvilkit/plugin-export-html": "workspace:*",
		"@anvilkit/plugin-export-react": "workspace:*",
		"@anvilkit/plugin-version-history": "workspace:*",
		"@anvilkit/pricing-minimal": "workspace:*",
		"@anvilkit/section": "workspace:*",
		"@anvilkit/statistics": "workspace:*",
		"@anvilkit/tailwind-config": "workspace:*",
		"@anvilkit/ui": "workspace:*",
