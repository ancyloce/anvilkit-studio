{
	"name": "@anvilkit/docs-site",
	"version": "0.0.4",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"dev": "vite dev",
		"build": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
		"preview": "vite preview",
		"start": "vite preview",
		"source": "fumadocs-mdx",
		"typecheck": "fumadocs-mdx && tsc --noEmit",
		"relay:hocuspocus": "node integrations/collab-relay.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"e2e": "playwright test",
		"e2e:install": "playwright install --with-deps chromium",
		"generate:templates": "node scripts/generate-template-pages.mjs",
		"generate:registry": "node scripts/generate-registry-feed.mjs",
		"generate:components": "jiti scripts/generate-component-pages.ts",
		"generate:plugins": "jiti scripts/generate-plugin-pages.ts",
		"generate:all": "pnpm generate:components && pnpm generate:api && pnpm generate:plugins && pnpm generate:templates && pnpm generate:registry",
		"generate:api": "jiti scripts/generate-api-pages.ts",
		"check:i18n": "node scripts/check-i18n.mjs",
		"docs:build": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
		"docs:dev": "vite dev"
	},
	"dependencies": {
		"@anvilkit/bento-grid": "workspace:*",
		"@anvilkit/blog-list": "workspace:*",
		"@anvilkit/button": "workspace:*",
		"@anvilkit/canvas-editor": "workspace:*",
		"@anvilkit/canvas-templates": "workspace:*",
		"@anvilkit/collab-ui": "workspace:*",
		"@anvilkit/core": "workspace:*",
		"@anvilkit/helps": "workspace:*",
		"@anvilkit/hero": "workspace:*",
		"@anvilkit/input": "workspace:*",
		"@anvilkit/ir": "workspace:*",
		"@anvilkit/logo-clouds": "workspace:*",
		"@anvilkit/navbar": "workspace:*",
		"@anvilkit/plugin-ai-copilot": "workspace:*",
		"@anvilkit/plugin-asset-manager": "workspace:*",
		"@anvilkit/plugin-canvas-studio": "workspace:*",
		"@anvilkit/plugin-collab-yjs": "workspace:*",
		"@anvilkit/plugin-design-system": "workspace:*",
		"@anvilkit/plugin-export-html": "workspace:*",
		"@anvilkit/plugin-export-react": "workspace:*",
		"@anvilkit/plugin-version-history": "workspace:*",
		"@anvilkit/pricing-minimal": "workspace:*",
		"@anvilkit/section": "workspace:*",
		"@anvilkit/statistics": "workspace:*",
		"@anvilkit/tailwind-config": "workspace:*",
		"@gsap/react": "^2.1.2",
		"@hocuspocus/provider": "^4.3.0",
		"@orama/tokenizers": "3.1.18",
		"@puckeditor/core": "^0.22.1",
		"@tanstack/react-router": "^1.170.0",
		"@tanstack/react-start": "^1.168.26",
		"fumadocs-core": "^16.10.5",
		"fumadocs-mdx": "^15.0.12",
		"fumadocs-ui": "^16.10.5",
		"gsap": "^3.15.0",
		"lucide-react": "^1.21.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"y-protocols": "^1.0.7",
		"yjs": "^13.6.31",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@anvilkit/validator": "workspace:*",
		"@hocuspocus/server": "^4.3.0",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.3.2",
		"@types/mdx": "^2.0.14",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript/native": "npm:typescript@7.0.2",
		"@vitejs/plugin-react": "^6.0.2",
		"happy-dom": "^20.8.9",
		"jiti": "^2.6.1",
		"nitro": "3.0.260610-beta",
		"tailwindcss": "^4.3.2",
		"typescript": "npm:@typescript/typescript6@6.0.2",
		"vite": "^8.0.16",
		"vitest": "^4.1.10"
	}
}
