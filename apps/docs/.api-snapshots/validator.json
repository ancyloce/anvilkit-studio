          }
        },
        {
          "id": 4,
          "name": "severity",
          "variant": "declaration",
          "kind": 1024,
          "flags": {
            "isReadonly": true
          },
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Severity of the issue.\n\n- "
              },
              {
                "kind": "code",
                "text": "`\"warn\"`"
              },
              {
                "kind": "text",
                "text": " — the response is usable but suspect (e.g. an\n  unexpected extra field).\n- "
              },
              {
                "kind": "code",
                "text": "`\"error\"`"
              },
              {
                "kind": "text",
                "text": " — the response is unusable (e.g. required field\n  missing, wrong type)."
              }
            ]
          },
          "sources": [
            {
              "fileName": "core/dist/types/ai.d.ts",
              "line": 221,
              "character": 13
            }
          ],
