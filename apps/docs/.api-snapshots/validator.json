      "id": 1,
      "name": "AiValidationIssue",
      "variant": "declaration",
      "kind": 256,
      "flags": {},
      "comment": {
        "summary": [
          {
            "kind": "text",
            "text": "A single issue produced by validating an LLM's response against\nthe expected component/field shape.\n\n"
          },
          {
            "kind": "code",
            "text": "`@anvilkit/validator`"
          },
          {
            "kind": "text",
            "text": " (Phase 3) owns the runtime check that emits\nthese; Core just owns the shape so validator output flows through\na stable contract."
          }
        ]
      },
      "children": [
        {
          "id": 3,
          "name": "message",
          "variant": "declaration",
          "kind": 1024,
          "flags": {
            "isReadonly": true
          },
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Human-readable message describing what went wrong. Suitable\nfor display in a dev console or a toast."
              }
            ]
          },
          "sources": [
            {
              "fileName": "core/dist/types/ai.d.ts",
              "line": 212,
              "character": 13
            }
          ],
          "type": {
            "type": "intrinsic",
            "name": "string"
          }
        },
        {
          "id": 2,
          "name": "path",
          "variant": "declaration",
          "kind": 1024,
          "flags": {
            "isReadonly": true
          },
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "JSON-pointer-style path to the offending value inside the LLM\nresponse (e.g. "
              },
              {
                "kind": "code",
                "text": "`\"content.0.props.title\"`"
              },
              {
                "kind": "text",
                "text": "). Empty string means\nthe issue applies to the response as a whole."
              }
            ]
          },
          "sources": [
            {
              "fileName": "core/dist/types/ai.d.ts",
              "line": 207,
              "character": 13
            }
          ],
          "type": {
            "type": "intrinsic",
