        {
          "id": 2,
          "name": "collectAssets",
          "variant": "signature",
          "kind": 4096,
          "flags": {},
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Walk a node's props and collect every asset reference into a\ndeduplicated, deterministically-ordered list.\n\nUsed by "
              },
              {
                "kind": "code",
                "text": "`puckDataToIR`"
              },
              {
                "kind": "text",
                "text": " to populate the root\n"
              },
              {
                "kind": "inline-tag",
                "tag": "@link",
                "text": "PageIR.assets"
              },
              {
                "kind": "text",
                "text": " manifest, and by node-scoped exporters\nthat want to resolve only their own slice of the asset graph.\n\n**Does not fetch or read files** — asset collection is purely\nstatic analysis of prop values."
              }
            ],
            "blockTags": [
              {
                "tag": "@returns",
                "content": [
                  {
                    "kind": "text",
                    "text": "A deduplicated list of assets, ordered by first encounter."
                  }
                ]
              }
            ]
          },
