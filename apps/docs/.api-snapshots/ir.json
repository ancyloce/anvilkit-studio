      "signatures": [
        {
          "id": 11,
          "name": "irToPuckData",
          "variant": "signature",
          "kind": 4096,
          "flags": {},
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Reverse of "
              },
              {
                "kind": "inline-tag",
                "tag": "@link",
                "text": "puckDataToIR",
                "target": 21
              },
              {
                "kind": "text",
                "text": ": rebuild a Puck "
              },
              {
                "kind": "code",
                "text": "`Data`"
              },
              {
                "kind": "text",
                "text": " document\nfrom a "
              },
              {
                "kind": "inline-tag",
                "tag": "@link",
                "text": "PageIR",
                "target": {
                  "packageName": "@anvilkit/core",
                  "packagePath": "src/types/ir.ts",
                  "qualifiedName": "PageIR"
                }
              },
              {
                "kind": "text",
                "text": ".\n\nThis function proves the round-trip guarantee — the invariant\n"
              },
              {
                "kind": "code",
                "text": "`irToPuckData(puckDataToIR(d)) ≡ d`"
              },
              {
                "kind": "text",
                "text": " is what lets us snapshot\ntest IR shapes without drift. It is also the entry point the AI\ncopilot plugin uses to turn a validated LLM "
              },
              {
                "kind": "code",
                "text": "`PageIR`"
              },
              {
                "kind": "text",
                "text": " response\nback into a "
              },
              {
                "kind": "code",
                "text": "`setData`"
              },
              {
                "kind": "text",
                "text": " payload.\n\nReturns a plain (un-frozen) Puck "
              },
              {
                "kind": "code",
                "text": "`Data`"
              },
              {
                "kind": "text",
                "text": " so Puck can mutate it."
              }
            ],
            "blockTags": [
              {
                "tag": "@returns",
                "content": [
                  {
                    "kind": "text",
                    "text": "A Puck "
                  },
                  {
                    "kind": "code",
                    "text": "`Data`"
                  },
                  {
                    "kind": "text",
                    "text": " equivalent to the IR input."
                  }
                ]
              }
            ]
          },
