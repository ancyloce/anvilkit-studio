        "blockTags": [
          {
            "tag": "@file",
            "content": [
              {
                "kind": "text",
                "text": "Public barrel for "
              },
              {
                "kind": "code",
                "text": "`@anvilkit/ir`"
              },
              {
                "kind": "text",
                "text": ".\n\nThe IR package is the single source of truth for turning Puck\n"
              },
              {
                "kind": "code",
                "text": "`Data`"
              },
              {
                "kind": "text",
                "text": " into a normalized "
              },
              {
                "kind": "inline-tag",
                "tag": "@link",
                "text": "PageIR"
              },
              {
                "kind": "text",
                "text": " document, and for round-\ntripping it back. Every Anvilkit export format (HTML today,\nReact/JSON/MDX later) consumes IR — never raw Puck "
              },
              {
                "kind": "code",
                "text": "`Data`"
              },
              {
                "kind": "text",
                "text": " — so\nthis barrel is the entry point every downstream package pins\nagainst."
              }
            ]
          },
          {
            "tag": "@see",
            "content": [
              {
                "kind": "inline-tag",
                "tag": "@link",
                "text": "file://./../../../docs/tasks/phase3-002-ir-scaffold.md | phase3-002"
