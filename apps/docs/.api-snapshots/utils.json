      "variant": "declaration",
      "kind": 64,
      "flags": {},
      "sources": [
        {
          "fileName": "generate-id.ts",
          "line": 19,
          "character": 16,
          "url": "https://github.com/ancyloce/anvilkit-studio/blob/main/packages/utils/src/generate-id.ts#L19"
        }
      ],
      "signatures": [
        {
          "id": 20,
          "name": "generateId",
          "variant": "signature",
          "kind": 4096,
          "flags": {},
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Generates a collision-resistant identifier.\n\nPrefers "
              },
              {
                "kind": "code",
                "text": "`crypto.randomUUID()`"
              },
              {
                "kind": "text",
                "text": " (RFC 4122 v4, cryptographically strong,\navailable in all modern browsers and Node.js ≥ 16.7) and falls back\nto a "
              },
              {
                "kind": "code",
                "text": "`Math.random()`"
              },
              {
                "kind": "text",
                "text": "-based v4-shaped string for legacy environments\nsuch as JSDOM < 16 or locked-down sandboxes without Web Crypto."
              }
            ],
            "blockTags": [
              {
                "tag": "@returns",
                "content": [
                  {
                    "kind": "text",
                    "text": "A unique string of the form "
                  },
                  {
                    "kind": "code",
                    "text": "`\"<prefix>-<uuid>\"`"
                  },
                  {
                    "kind": "text",
                    "text": " or just the\n  bare UUID when no prefix is given."
                  }
                ]
              },
              {
                "tag": "@example",
                "content": [
                  {
                    "kind": "code",
                    "text": "```ts\ngenerateId();           // \"0192ac5e-a9b3-7ce0-b4a9-9f4f8a4f5d2b\"\ngenerateId(\"plugin\");   // \"plugin-0192ac5e-a9b3-7ce0-b4a9-9f4f8a4f5d2b\"\n```"
                  }
                ]
              }
            ]
          },
          "sources": [
            {
              "fileName": "generate-id.ts",
              "line": 19,
              "character": 16,
              "url": "https://github.com/ancyloce/anvilkit-studio/blob/main/packages/utils/src/generate-id.ts#L19"
            }
          ],
          "parameters": [
            {
              "id": 21,
              "name": "prefix",
              "variant": "param",
              "kind": 32768,
              "flags": {
                "isOptional": true
              },
              "comment": {
                "summary": [
                  {
                    "kind": "text",
                    "text": "Optional namespace segment joined with a "
                  },
                  {
                    "kind": "code",
                    "text": "`-`"
                  },
                  {
                    "kind": "text",
                    "text": ". Use this\n  to label IDs by origin (e.g. "
                  },
                  {
                    "kind": "code",
                    "text": "`\"plugin\"`"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "`\"node\"`"
                  },
                  {
                    "kind": "text",
                    "text": ") so they are easy\n  to spot in logs and React DevTools."
                  }
                ]
              },
              "type": {
                "type": "intrinsic",
                "name": "string"
              }
            }
          ],
          "type": {
