          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Asserts that "
              },
              {
                "kind": "code",
                "text": "`condition`"
              },
              {
                "kind": "text",
                "text": " is truthy, throwing an "
              },
              {
                "kind": "code",
                "text": "`Error`"
              },
              {
                "kind": "text",
                "text": " with the\ngiven "
              },
              {
                "kind": "code",
                "text": "`message`"
              },
              {
                "kind": "text",
                "text": " otherwise. Because the return type is\n"
              },
              {
                "kind": "code",
                "text": "`asserts condition`"
              },
              {
                "kind": "text",
                "text": ", TypeScript narrows "
              },
              {
                "kind": "code",
                "text": "`condition`"
              },
              {
                "kind": "text",
                "text": " for the caller\non the success path — no "
              },
              {
                "kind": "code",
                "text": "`if`"
              },
              {
                "kind": "text",
                "text": "/"
              },
              {
                "kind": "code",
                "text": "`throw`"
              },
              {
                "kind": "text",
                "text": " boilerplate required.\n\nUse this at boundaries where a "
              },
              {
                "kind": "code",
                "text": "`\"this should never happen\"`"
              },
              {
                "kind": "text",
                "text": "\ninvariant must hold (e.g. the plugin engine receiving a compiled\nruntime that claims a plugin exists by id). Do **not** use it for\nuser-facing validation — reach for "
              },
              {
                "kind": "code",
                "text": "`@anvilkit/validator`"
              },
              {
                "kind": "text",
                "text": " for that."
              }
            ],
            "blockTags": [
              {
                "tag": "@example",
                "content": [
                  {
                    "kind": "code",
                    "text": "```ts\nfunction getPlugin(id: string) {\n  const plugin = registry.get(id);\n  invariant(plugin, `Plugin \"${id}\" is not registered`);\n  // TS now knows `plugin` is not undefined.\n  return plugin;\n}\n```"
                  }
                ]
              }
            ]
