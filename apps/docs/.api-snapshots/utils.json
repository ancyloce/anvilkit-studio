        }
      ],
      "signatures": [
        {
          "id": 2,
          "name": "debounce",
          "variant": "signature",
          "kind": 4096,
          "flags": {},
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Returns a debounced version of "
              },
              {
                "kind": "code",
                "text": "`fn`"
              },
              {
                "kind": "text",
                "text": " that delays invocation until\n"
              },
              {
                "kind": "code",
                "text": "`wait`"
              },
              {
                "kind": "text",
                "text": " milliseconds have elapsed since the last call. If the returned\nfunction is called again within the window, the timer resets. Calling\n"
              },
              {
                "kind": "code",
                "text": "`.cancel()`"
              },
              {
                "kind": "text",
                "text": " drops any pending invocation without firing "
              },
              {
                "kind": "code",
                "text": "`fn`"
              },
              {
                "kind": "text",
                "text": ".\n\nThe returned function always resolves to "
              },
              {
                "kind": "code",
                "text": "`undefined`"
              },
              {
                "kind": "text",
                "text": " synchronously —\nthe real return value of "
              },
              {
                "kind": "code",
                "text": "`fn`"
              },
              {
                "kind": "text",
                "text": " is dropped because it is deferred. The\ntype-level "
              },
              {
                "kind": "code",
                "text": "`T &`"
              },
              {
                "kind": "text",
                "text": " intersection exists so callers retain the original\nparameter tuple; it does **not** imply the return value is preserved."
              }
            ],
            "blockTags": [
              {
                "tag": "@returns",
                "content": [
                  {
                    "kind": "text",
                    "text": "A debounced function with a "
                  },
                  {
                    "kind": "code",
                    "text": "`.cancel()`"
                  },
                  {
                    "kind": "text",
                    "text": " method."
                  }
                ]
              },
              {
                "tag": "@example",
                "content": [
                  {
                    "kind": "code",
                    "text": "```ts\nconst save = debounce((data: FormData) => api.save(data), 300);\nsave(formA); // pending\nsave(formB); // resets timer, formA is dropped\n// 300ms later → api.save(formB) fires.\nsave.cancel(); // drops formB if still pending.\n```"
                  }
                ]
              }
            ]
          },
          "sources": [
            {
              "fileName": "debounce.ts",
              "line": 38,
              "character": 16,
              "url": "https://github.com/ancyloce/anvilkit-studio/blob/main/packages/utils/src/debounce.ts#L38"
            }
          ],
