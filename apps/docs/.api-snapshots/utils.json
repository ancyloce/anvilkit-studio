    {
      "id": 22,
      "name": "getStrictContext",
      "variant": "declaration",
      "kind": 64,
      "flags": {},
      "sources": [
        {
          "fileName": "get-strict-context.ts",
          "line": 48,
          "character": 16,
          "url": "https://github.com/ancyloce/anvilkit-studio/blob/main/packages/utils/src/get-strict-context.ts#L48"
        }
      ],
      "signatures": [
        {
          "id": 23,
          "name": "getStrictContext",
          "variant": "signature",
          "kind": 4096,
          "flags": {},
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Creates a React context paired with a hook that throws a descriptive\nerror when used outside its provider. The returned tuple is designed\nto be destructured into a single module, producing the common\n"
              },
              {
                "kind": "code",
                "text": "`<FooProvider>`"
              },
              {
                "kind": "text",
                "text": " + "
              },
              {
                "kind": "code",
                "text": "`useFoo()`"
              },
              {
                "kind": "text",
                "text": " pattern with no repeated boilerplate.\n\nWhy this exists instead of using "
              },
              {
                "kind": "code",
                "text": "`createContext`"
              },
              {
                "kind": "text",
                "text": " directly:\n\n- Missing-provider bugs are one of the most common React footguns\n  and the default behavior (silently return the context default) is\n  the worst possible outcome — consumers see "
              },
              {
                "kind": "code",
                "text": "`undefined`"
              },
              {
                "kind": "text",
                "text": " deep inside\n  a component tree with no stack trace pointing at the real cause.\n- Hand-rolling the throw-if-unset check on every context adds noise\n  and gets forgotten. Centralizing it here makes it automatic."
              }
            ],
            "blockTags": [
              {
                "tag": "@returns",
                "content": [
                  {
                    "kind": "text",
                    "text": "A tuple "
                  },
                  {
                    "kind": "code",
                    "text": "`[Provider, useContext]`"
                  },
                  {
                    "kind": "text",
                    "text": " ready to be destructured."
                  }
                ]
              },
              {
                "tag": "@example",
                "content": [
                  {
                    "kind": "code",
