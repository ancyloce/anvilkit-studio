{
	"name": "@anvilkit/example-export-json",
	"version": "0.1.0",
	"description": "Worked example for the AnvilKit export pipeline guide — a minimal StudioPlugin that ships a JSON export format.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"private": false,
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"license": "MIT",
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@anvilkit/core": "^0.1.0-alpha",
		"@puckeditor/core": "^0.21.0"
	},
	"devDependencies": {
		"@anvilkit/core": "workspace:*",
		"@anvilkit/ir": "workspace:*",
		"@anvilkit/typescript-config": "workspace:*",
		"@puckeditor/core": "^0.21.1",
		"@rslib/core": "^0.20.1",
		"@types/node": "^22.15.3",
		"typescript": "6.0.2",
		"vitest": "^4.1.4"
	},
	"scripts": {
		"build": "rslib build",
		"dev": "rslib build --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	}
}
