{
	"name": "@anvilkit/example-usage-counter",
	"version": "0.1.0",
	"description": "Worked example for the AnvilKit plugin authoring guide — counts how many times each component appears on the page.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"private": true,
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"license": "MIT",
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@anvilkit/core": "^0.1.4",
		"@puckeditor/core": "^0.21.3"
	},
	"devDependencies": {
		"@anvilkit/core": "workspace:*",
		"@anvilkit/typescript-config": "workspace:*",
		"@puckeditor/core": "^0.21.3",
		"@rslib/core": "^0.23.0",
		"@types/node": "^26.0.0",
		"typescript": "6.0.3",
		"vitest": "^4.1.9"
	},
	"scripts": {
		"build": "rslib build",
		"dev": "rslib build --watch",
		"format": "pnpm exec biome format --write src rslib.config.ts vitest.config.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	}
}
