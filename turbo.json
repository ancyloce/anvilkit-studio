{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"format": {
			"cache": false
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"anvilkit-components#typecheck": {
			"dependsOn": ["^build", "@anvilkit/ui#build", "@anvilkit/utils#build"]
		},
		"anvilkit-components#build": {
			"dependsOn": ["^build", "@anvilkit/ui#build", "@anvilkit/utils#build"]
		},
		"@anvilkit/docs-site#build": {
			"dependsOn": ["^build"],
			"inputs": [
				"vite.config.ts",
				"source.config.ts",
				"package.json",
				"tsconfig.json",
				"src/**",
				"content/**",
				"public/**"
			],
			"outputs": ["dist/**", ".output/**", ".nitro/**", ".vercel/output/**"]
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": ["coverage/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"e2e": {
			"cache": false,
			"dependsOn": ["^build"]
		},
		"publint": {
			"dependsOn": ["^build"]
		},
		"check:all": {
			"dependsOn": ["build", "^check:all"],
			"cache": false
		},
		"size": {
			"dependsOn": ["build"],
			"inputs": ["dist/**", ".size-limit.json", "package.json"],
			"outputs": []
		},
		"docs:build": {
			"dependsOn": ["^build"],
			"inputs": [
				"vite.config.ts",
				"source.config.ts",
				"package.json",
				"tsconfig.json",
				"src/**",
				"content/**",
				"public/**"
			],
			"outputs": ["dist/**", ".output/**", ".nitro/**", ".vercel/output/**"]
		},
		"docs:dev": {
			"cache": false,
			"persistent": true
		}
	},
	"concurrency": "32"
}
