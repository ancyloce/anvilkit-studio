{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "publint": {
      "dependsOn": ["^build"]
    },
    "docs:build": {
      "dependsOn": ["^build"],
      "inputs": [
        "astro.config.mjs",
        "package.json",
        "tsconfig.json",
        "src/**",
        "public/**"
      ],
      "outputs": ["dist/**", ".astro/**"]
    },
    "docs:dev": {
      "cache": false,
      "persistent": true
    }
  }
}
