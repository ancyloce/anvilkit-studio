# docker-compose.yml overrides — copy to `.env` and edit, then `docker compose up -d`.
# Compose auto-reads `.env` from this directory. Every value is OPTIONAL: the
# defaults make the stack work on http://localhost out of the box, with the
# `proxy` (Caddy) service as the single public entry point. The demo and the
# collab relay are NOT exposed directly — the proxy tunnels the collab
# WebSocket to the relay over the internal Docker network.

# Public domain for the edge. Set it to enable automatic HTTPS + WSS via
# Let's Encrypt (needs ports 80+443 reachable and DNS pointing at the host).
# Empty (default) = plain HTTP on :80, good for localhost / IP testing.
#   PUBLIC_DOMAIN=demo.example.com

# Restrict which page origins may open a collab WebSocket. Comma-separated.
# Empty (default) = accept ANY origin. The relay is internal-only and same-
# origin with the app, so this is safe; set it for defense-in-depth.
#   DEMO_ALLOWED_ORIGINS=https://demo.example.com

# Pin the browser-reachable relay URL. ONLY needed when the relay is reached
# directly instead of through the proxy `/collab-ws` path (the default). Behind
# HTTPS you MUST use wss:// (a ws:// URL is blocked as mixed content).
#   COLLAB_PUBLIC_WS_URL=wss://relay.example.com/collab-ws
