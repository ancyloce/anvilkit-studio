# pnpm 10.13+ defaults `strict-dep-builds=true`, which turns
# "ignored install scripts" (e.g. esbuild, msw) into a hard error.
# The nested `packages/components` workspace has no build approvals
# of its own, so any install in that workspace would fail.
# Downgrade the gate to a warning.
strict-dep-builds=false

# pnpm 11 runs a deps-status check before `pnpm run <script>` and
# spawns `pnpm install` when it thinks the workspace is out of sync.
# Because the components workspace can never satisfy that check
# (esbuild/msw scripts are always reported as ignored), every
# `pnpm run build` in a component leaf would re-trigger a failing
# install. Disable the auto-check; CI installs the components
# workspace explicitly before running builds.
verify-deps-before-run=false
