{
	"$schema": "https://typedoc.org/schema.json",
	"plugin": ["typedoc-plugin-markdown"],
	"excludePrivate": true,
	"excludeProtected": true,
	"excludeInternal": true,
	"excludeExternals": true,
	"exclude": [
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.spec.ts",
		"**/*.spec.tsx",
		"**/internal/**",
		"**/_*.ts",
		"**/_*.tsx"
	],
	"hideGenerator": true,
	"readme": "none",
	"githubPages": false,
	"sourceLinkTemplate": "https://github.com/ancyloce/anvilkit-studio/blob/main/{path}#L{line}",
	"hideBreadcrumbs": true,
	"hidePageHeader": true,
	"useCodeBlocks": true,
	"expandObjects": true,
	"parametersFormat": "table",
	"propertiesFormat": "table",
	"enumMembersFormat": "table",
	"typeDeclarationFormat": "table",
	"indexFormat": "table",
	"flattenOutputFiles": false,
	"entryFileName": "index.md",
	"logLevel": "Warn",
	"skipErrorChecking": false,
	"blockTags": [
		"@alpha",
		"@beta",
		"@category",
		"@categoryDescription",
		"@default",
		"@defaultValue",
		"@deprecated",
		"@document",
		"@event",
		"@eventProperty",
		"@example",
		"@experimental",
		"@file",
		"@group",
		"@groupDescription",
		"@import",
		"@inheritDoc",
		"@internal",
		"@license",
		"@module",
		"@mergeModuleWith",
		"@param",
		"@privateRemarks",
		"@property",
		"@public",
		"@remarks",
		"@returns",
		"@satisfies",
		"@sealed",
		"@see",
		"@since",
		"@template",
		"@throws",
		"@typeParam",
		"@virtual"
	]
}
